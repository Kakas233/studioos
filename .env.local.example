# ============================================
# StudioOS Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# --- Supabase ---
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=https://getstudioos.com
NEXT_PUBLIC_APP_NAME=StudioOS

# --- VPS (Member Alerts Monitoring) ---
# Set this to your VPS HTTPS domain (NOT the raw IP)
NEXT_PUBLIC_VPS_URL=https://alerts.getstudioos.com

# --- Stripe ---
# Get these from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Email (Resend) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- Telegram Bot ---
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# --- Super Admin ---
SUPER_ADMIN_EMAIL=your-admin@email.com

# --- AI (Claude API for Recommendations + Support Chat) ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Cron Jobs ---
CRON_SECRET=
